{
    "version": 2,
    "public": true,
    "routes": [
        {
            "src": "/manifest.webmanifest",
            "dest": "/manifest.webmanifest",
            "headers": {
                "Content-Type": "application/manifest+json",
                "Cache-Control": "public, max-age=0, must-revalidate"
            }
        },
        {
            "src": "/service-worker.js",
            "dest": "/service-worker.js",
            "headers": {
                "Cache-Control": "public, max-age=0, must-revalidate"
            }
        }
    ]
}